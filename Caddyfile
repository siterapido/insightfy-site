# Caddyfile — Reverse proxy with automatic HTTPS for Insightfy
#
# Customize with your domain and email for Let's Encrypt / ZeroSSL notifications.

{
    # Your email address for ACME registration / certificate renewals
    email your-email@example.com
}

# Redirect www to apex (optional, but highly recommended for SEO)
www.insightfy.com.br {
    redir https://insightfy.com.br{uri}
}

# Serve the main domain
insightfy.com.br {
    # Reverse proxy to the Next.js standalone container
    reverse_proxy web:3000

    # Compression for static files and API responses
    encode gzip zstd

    # Header configurations for security (HSTS, clickjacking protection, etc.)
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Enable logging for troubleshooting and analytics
    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}
